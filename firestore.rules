rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function currentUserExists() {
      return signedIn()
        && exists(userPath(request.auth.uid));
    }

    function currentUserData() {
      return get(userPath(request.auth.uid)).data;
    }

    function activeUser() {
      return currentUserExists()
        && (
          !('isActive' in currentUserData())
          || currentUserData().isActive == true
        );
    }

    function isAdmin() {
      return activeUser()
        && currentUserData().role == 'admin';
    }

    function isProvider() {
      return activeUser()
        && currentUserData().role == 'provider'
        && currentUserData().providerStatus == 'approved';
    }

    function validBookingStatus(status) {
      return status in [
        'pending',
        'pending_provider',
        'awaiting_payment',
        'payment_review',
        'confirmed',
        'completed',
        'cancelled',
        'rejected',
        'expired'
      ];
    }

    function validPaymentStatus(status) {
      return status in [
        'unpaid',
        'submitted',
        'paid',
        'rejected',
        'expired'
      ];
    }

    function validCommissionStatus(status) {
      return status in [
        'unpaid',
        'payment_review',
        'paid',
        'overdue',
        'rejected'
      ];
    }

    function validViolationStatus(status) {
      return status in [
        'draft',
        'waitingProvider',
        'investigating',
        'confirmed',
        'noPenalty',
        'appealed',
        'cancelled',
        'paid'
      ];
    }

    function validViolationType(type) {
  return type in [
    'serviceQuality',
    'incorrectInformation',
    'hygiene',
    'customerSafety',
    'paymentDispute',
    'providerBehavior',
    'bookingViolation',
    'other'
  ];
}

    function paymentProfilePath(providerId) {
      return /databases/$(database)
        /documents/providerPaymentProfiles/$(providerId);
    }

    function verifiedPaymentProfile(providerId) {
      let path = paymentProfilePath(providerId);

      return exists(path)
        && get(path).data.isVerified == true
        && get(path).data.verificationStatus
          == 'approved';
    }

    function paymentProfileMatchesBooking(providerId) {
      let profile = get(
        paymentProfilePath(providerId)
      ).data;

      return verifiedPaymentProfile(providerId)
        && request.resource.data.receiverBankBin
          == profile.bankBin
        && request.resource.data.receiverBankName
          == profile.bankName
        && request.resource.data.receiverAccountNumber
          == profile.accountNumber
        && request.resource.data.receiverAccountName
          == profile.accountName;
    }

    /*
 * USERS
 */
match /users/{userId} {
  /*
   * Cập nhật thông tin hồ sơ thông thường.
   */
  function ownerProfileUpdate() {
    let changed = request.resource.data
      .diff(resource.data)
      .affectedKeys();

    return activeUser()
      && request.auth.uid == userId
      && request.resource.data.uid
        == resource.data.uid
      && request.resource.data.role
        == resource.data.role
      && request.resource.data.providerStatus
        == resource.data.providerStatus
      && changed.hasOnly([
        'fullName',
        'phoneNumber',
        'profilePic',
        'updatedAt'
      ]);
  }

  /*
   * Kiểm tra cấu hình thông báo do khách cập nhật.
   */
  function validNotificationSettings(changed) {
    return !changed.hasAny([
      'notificationSettings'
    ])
    || (
      request.resource.data.notificationSettings
        is map
      && request.resource.data
        .notificationSettings
        .keys()
        .hasOnly([
          'bookingUpdates',
          'promotions',
          'travelSuggestions'
        ])
      && request.resource.data
        .notificationSettings
        .bookingUpdates is bool
      && request.resource.data
        .notificationSettings
        .promotions is bool
      && request.resource.data
        .notificationSettings
        .travelSuggestions is bool
    );
  }

  /*
   * Kiểm tra thời điểm khách xem voucher.
   *
   * lastSeenVoucherAt bắt buộc là server timestamp,
   * không cho khách tự nhập một thời điểm tùy ý.
   */
  function validLastSeenVoucherAt(changed) {
    return !changed.hasAny([
      'lastSeenVoucherAt'
    ])
    || (
      request.resource.data.lastSeenVoucherAt
        is timestamp
      && request.resource.data.lastSeenVoucherAt
        == request.time
    );
  }

  /*
   * Khách được cập nhật:
   * - Cài đặt thông báo của chính mình.
   * - Thời điểm đã xem voucher.
   *
   * Không được thay đổi role, trạng thái tài khoản
   * hoặc thông tin phân quyền.
   */
  function ownerNotificationUpdate() {
    let changed = request.resource.data
      .diff(resource.data)
      .affectedKeys();

    return activeUser()
      && request.auth.uid == userId
      && changed.hasOnly([
        'notificationSettings',
        'lastSeenVoucherAt',
        'updatedAt'
      ])
      && request.resource.data.updatedAt
        is timestamp
      && request.resource.data.updatedAt
        == request.time
      && validNotificationSettings(changed)
      && validLastSeenVoucherAt(changed);
  }

  /*
   * Khách gửi yêu cầu đăng ký nhà cung cấp.
   */
  function submitProviderApplication() {
    let applicationPath = /databases/$(database)
      /documents/providerApplications/$(userId);

    let changed = request.resource.data
      .diff(resource.data)
      .affectedKeys();

    return activeUser()
      && request.auth.uid == userId
      && resource.data.role == 'customer'
      && request.resource.data.role == 'customer'
      && request.resource.data.providerStatus
        == 'pending'
      && changed.hasOnly([
        'providerStatus',
        'updatedAt'
      ])
      && existsAfter(applicationPath)
      && getAfter(applicationPath).data.userId
        == userId
      && getAfter(applicationPath).data.status
        == 'pending';
  }

  /*
   * Khách chỉ đọc tài khoản của chính mình.
   * Admin được đọc tất cả.
   */
  allow read: if activeUser()
    && (
      request.auth.uid == userId
      || isAdmin()
    );

  /*
   * Tạo tài khoản mới.
   */
  allow create: if signedIn()
    && request.auth.uid == userId
    && request.resource.data.keys().hasOnly([
      'uid',
      'email',
      'fullName',
      'phoneNumber',
      'role',
      'providerStatus',
      'profilePic',
      'isActive',
      'createdAt',
      'updatedAt'
    ])
    && request.resource.data.uid == userId
    && request.resource.data.role == 'customer'
    && request.resource.data.providerStatus
      == 'none'
    && request.resource.data.email is string
    && request.resource.data.email.size() > 3
    && request.resource.data.fullName is string
    && (
      !('isActive' in request.resource.data)
      || request.resource.data.isActive == true
    );

  /*
   * Admin được cập nhật mọi tài khoản.
   *
   * Khách chỉ được:
   * - Sửa hồ sơ.
   * - Sửa cài đặt thông báo.
   * - Đánh dấu đã xem voucher.
   * - Gửi yêu cầu làm nhà cung cấp.
   */
  allow update: if isAdmin()
    || ownerProfileUpdate()
    || ownerNotificationUpdate()
    || submitProviderApplication();

  allow delete: if isAdmin();
}

    /*
     * PROVIDER APPLICATIONS
     */
    match /providerApplications/{applicationId} {
      function validOwnerApplication() {
        return activeUser()
          && request.auth.uid == applicationId
          && request.resource.data.userId
            == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.businessName is string
          && request.resource.data.businessName.size() >= 2
          && request.resource.data.representativeName
            is string
          && request.resource.data.phoneNumber is string
          && request.resource.data.address is string
          && request.resource.data.identityNumber is string
          && request.resource.data.identityFrontUrl is string
          && request.resource.data.identityBackUrl is string
          && request.resource.data.businessLicenseUrl
            is string
          && request.resource.data.rejectionReason == ''
          && request.resource.data.reviewedBy == '';
      }

      allow read: if activeUser()
        && (
          request.auth.uid == applicationId
          || isAdmin()
        );

      allow create: if validOwnerApplication();

      allow update: if isAdmin()
        || (
          validOwnerApplication()
          && resource.data.userId == request.auth.uid
          && resource.data.status in [
            'rejected',
            'pending'
          ]
        );

      allow delete: if isAdmin();
    }

    /*
     * PROVIDER PROFILES
     */
    match /providers/{providerId} {
      allow read: if activeUser()
        && (
          request.auth.uid == providerId
          || isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    /*
     * HOTELS
     */
    match /hotels/{hotelId} {
      function validHotelOwner() {
        return request.resource.data.providerId
          == request.auth.uid;
      }

      function validHotelData() {
  return request.resource.data.name is string
    && request.resource.data.name.size() >= 2
    && request.resource.data.name.size() <= 150
    && request.resource.data.address is string
    && request.resource.data.address.size() >= 3
    && request.resource.data.address.size() <= 300
    && request.resource.data.province is string
    && request.resource.data.province.size() >= 2
    && request.resource.data.province.size() <= 100
    && request.resource.data.district is string
    && request.resource.data.district.size() >= 2
    && request.resource.data.district.size() <= 100
    && request.resource.data.description is string
    && request.resource.data.description.size() <= 3000
    && request.resource.data.images is list
    && request.resource.data.images.size() >= 1
    && request.resource.data.images.size() <= 50
    && request.resource.data.category is string
    && request.resource.data.category in [
      'Khách sạn',
      'Căn hộ',
      'Biệt thự',
      'Homestay',
      'Resort',
      'Nhà nghỉ'
    ]
    && request.resource.data.contactEmail is string
    && request.resource.data.contactEmail.size() <= 254
    && request.resource.data.contactPhone is string
    && request.resource.data.contactPhone.size() >= 10
    && request.resource.data.contactPhone.size() <= 15
    && request.resource.data.zaloPhone is string
    && request.resource.data.zaloPhone.size() <= 15
    && request.resource.data.facebookUrl is string
    && request.resource.data.facebookUrl.size() <= 500
    && request.resource.data.rating is number
    && request.resource.data.rating >= 0
    && request.resource.data.rating <= 5
    && request.resource.data.minPrice is number
    && request.resource.data.minPrice >= 0
    && request.resource.data.minHourlyPrice is number
    && request.resource.data.minHourlyPrice >= 0
    && request.resource.data.minFirstHourPrice is number
    && request.resource.data.minFirstHourPrice >= 0
    && request.resource.data.minAdditionalHourPrice is number
    && request.resource.data.minAdditionalHourPrice >= 0;
}
      allow read: if activeUser();

      allow create: if isProvider()
        && validHotelOwner()
        && validHotelData();

      allow update: if isAdmin()
        || (
          isProvider()
          && resource.data.providerId
            == request.auth.uid
          && request.resource.data.providerId
            == resource.data.providerId
          && request.resource.data.rating
            == resource.data.rating
          && request.resource.data.status
            == resource.data.status
          && validHotelData()
        );

      allow delete: if isAdmin()
        || (
          isProvider()
          && resource.data.providerId
            == request.auth.uid
        );
    }

    /*
     * ROOMS
     */
    match /rooms/{roomId} {
      function destinationHotelPath() {
        return /databases/$(database)
          /documents/hotels/$(request.resource.data.hotelId);
      }

      function ownsDestinationHotel() {
        return request.resource.data.hotelId is string
          && request.resource.data.hotelId.size() > 0
          && exists(destinationHotelPath())
          && get(destinationHotelPath()).data.providerId
            == request.auth.uid;
      }

      function validRoomData() {
        return request.resource.data.roomNumber is string
          && request.resource.data.roomNumber.size() > 0
          && request.resource.data.type is string
          && request.resource.data.price is number
          && request.resource.data.hourlyPrice is number
          && request.resource.data.hourlyPrice > 0
          && request.resource.data.firstHourPrice
            is number
          && request.resource.data.firstHourPrice > 0
          && request.resource.data.additionalHourPrice
            is number
          && request.resource.data.additionalHourPrice > 0
          && request.resource.data.weekendSurchargePercent
            is number
          && request.resource.data.weekendSurchargePercent
            >= 0
          && request.resource.data.weekendSurchargePercent
            <= 100
          && request.resource.data.holidaySurchargePercent
            is number
          && request.resource.data.holidaySurchargePercent
            >= 0
          && request.resource.data.holidaySurchargePercent
            <= 100
          && request.resource.data.maxGuests is int
          && request.resource.data.maxGuests > 0
          && request.resource.data.isAvailable is bool
          && request.resource.data.images is list
          && request.resource.data.amenities is list
          && request.resource.data.ratePlans is list;
      }

      allow read: if activeUser();

      allow create: if isProvider()
        && request.resource.data.providerId
          == request.auth.uid
        && ownsDestinationHotel()
        && validRoomData();

      allow update: if isAdmin()
        || (
          isProvider()
          && resource.data.providerId
            == request.auth.uid
          && request.resource.data.providerId
            == resource.data.providerId
          && ownsDestinationHotel()
          && validRoomData()
        );

      allow delete: if isAdmin()
        || (
          isProvider()
          && resource.data.providerId
            == request.auth.uid
        );
    }

    /*
     * BOOKINGS
     */
    match /bookings/{bookingId} {
      function bookingRoomPath() {
        return /databases/$(database)
          /documents/rooms/$(request.resource.data.roomId);
      }

      function bookingRoom() {
        return get(bookingRoomPath()).data;
      }

      function roomFirstHourPrice() {
        return 'firstHourPrice' in bookingRoom()
          ? bookingRoom().firstHourPrice
          : bookingRoom().hourlyPrice;
      }

      function roomAdditionalHourPrice() {
        return 'additionalHourPrice' in bookingRoom()
          ? bookingRoom().additionalHourPrice
          : bookingRoom().hourlyPrice;
      }

      function roomWeekendPercent() {
        return 'weekendSurchargePercent'
          in bookingRoom()
          ? bookingRoom().weekendSurchargePercent
          : 20;
      }

      function roomHolidayPercent() {
        return 'holidaySurchargePercent'
          in bookingRoom()
          ? bookingRoom().holidaySurchargePercent
          : 35;
      }

      function validBookingRoom() {
        return request.resource.data.roomId is string
          && exists(bookingRoomPath())
          && bookingRoom().isAvailable == true
          && bookingRoom().providerId
            == request.resource.data.providerId
          && bookingRoom().hotelId
            == request.resource.data.hotelId
          && request.resource.data.guests
            <= bookingRoom().maxGuests
          && request.resource.data.baseHourlyPrice
            == roomFirstHourPrice()
          && request.resource.data.firstHourPrice
            == roomFirstHourPrice()
          && request.resource.data.additionalHourPrice
            == roomAdditionalHourPrice()
          && request.resource.data.weekendSurchargePercent
            == roomWeekendPercent()
          && request.resource.data.holidaySurchargePercent
            == roomHolidayPercent();
      }

      function validWholeHour(value) {
  return value.minutes() == 0
    && value.seconds() == 0
    && value.nanos() == 0;
}

      function validBookingTime() {
        return request.resource.data.checkIn is timestamp
          && request.resource.data.checkOut is timestamp
          && request.resource.data.checkIn >= request.time
          && request.resource.data.checkOut
            >= request.resource.data.checkIn
              + duration.value(1, 'h')
          && request.resource.data.checkOut
            <= request.resource.data.checkIn
              + duration.value(30, 'd')
          && validWholeHour(
            request.resource.data.checkIn
          )
          && validWholeHour(
            request.resource.data.checkOut
          );
      }

      function validPricingSnapshot() {
        let usesCombo =
          request.resource.data.ratePlanId.size() > 0;

        return request.resource.data.totalAmount
            is number
          && request.resource.data.totalAmount > 0
          && request.resource.data.durationMinutes
            is int
          && request.resource.data.durationMinutes >= 60
          && request.resource.data.ratePlanId is string
          && request.resource.data.ratePlanPrice
            is number
          && request.resource.data.overtimeAmount
            is number
          && request.resource.data.calendarSurchargeAmount
            is number
          && request.resource.data.pricingBreakdown
            is map
          && (
            (
              !usesCombo
              && request.resource.data.ratePlanPrice == 0
            )
            || (
              usesCombo
              && request.resource.data.ratePlanName is string
              && request.resource.data.ratePlanName.size() > 0
              && request.resource.data.ratePlanPrice > 0
            )
          );
      }

      function scheduleContains(scheduleId) {
        let path = /databases/$(database)
          /documents/roomSchedules/$(scheduleId);

        return existsAfter(path)
          && getAfter(path).data.roomId
            == request.resource.data.roomId
          && getAfter(path).data
            .reservations[bookingId].bookingId
            == bookingId
          && getAfter(path).data
            .reservations[bookingId].roomId
            == request.resource.data.roomId
          && getAfter(path).data
            .reservations[bookingId].providerId
            == request.resource.data.providerId
          && getAfter(path).data
            .reservations[bookingId].checkIn
            == request.resource.data.checkIn
          && getAfter(path).data
            .reservations[bookingId].checkOut
            == request.resource.data.checkOut
          && getAfter(path).data
            .reservations[bookingId].active == true;
      }

      function scheduleHasState(
        scheduleId,
        expectedActive
      ) {
        let path = /databases/$(database)
          /documents/roomSchedules/$(scheduleId);

        return existsAfter(path)
          && getAfter(path).data
            .reservations[bookingId].active
            == expectedActive;
      }

      function validSchedules() {
        let ids = request.resource.data.scheduleIds;

        return ids is list
          && ids.size() >= 1
          && ids.size() <= 3
          && scheduleContains(ids[0])
          && (
            ids.size() < 2
            || scheduleContains(ids[1])
          )
          && (
            ids.size() < 3
            || scheduleContains(ids[2])
          );
      }

      function schedulesHaveState(expectedActive) {
        let ids = resource.data.scheduleIds;

        return ids is list
          && ids.size() >= 1
          && ids.size() <= 3
          && scheduleHasState(
            ids[0],
            expectedActive
          )
          && (
            ids.size() < 2
            || scheduleHasState(
              ids[1],
              expectedActive
            )
          )
          && (
            ids.size() < 3
            || scheduleHasState(
              ids[2],
              expectedActive
            )
          );
      }

      function customerBookingUpdate() {
        let changed = request.resource.data
          .diff(resource.data)
          .affectedKeys();

        let cancel =
          changed.hasOnly([
            'status',
            'updatedAt'
          ])
          && resource.data.status in [
            'pending',
            'pending_provider',
            'awaiting_payment'
          ]
          && request.resource.data.status
            == 'cancelled'
          && schedulesHaveState(false);

        let submitPayment =
          changed.hasOnly([
            'status',
            'paymentStatus',
            'paymentSubmittedAt',
            'updatedAt'
          ])
          && resource.data.status
            == 'awaiting_payment'
          && resource.data.paymentStatus in [
            'unpaid',
            'rejected'
          ]
          && resource.data.paymentDeadline
            is timestamp
          && request.time
            <= resource.data.paymentDeadline
          && request.resource.data.status
            == 'payment_review'
          && request.resource.data.paymentStatus
            == 'submitted';

        return activeUser()
          && resource.data.customerId
            == request.auth.uid
          && request.resource.data.customerId
            == resource.data.customerId
          && request.resource.data.providerId
            == resource.data.providerId
          && request.resource.data.roomId
            == resource.data.roomId
          && request.resource.data.totalAmount
            == resource.data.totalAmount
          && (
            cancel
            || submitPayment
          );
      }

      function providerBookingUpdate() {
        let changed = request.resource.data
          .diff(resource.data)
          .affectedKeys();

        let approve =
          resource.data.status in [
            'pending',
            'pending_provider'
          ]
          && request.resource.data.status
            == 'awaiting_payment'
          && request.resource.data.paymentStatus
            == 'unpaid'
          && request.resource.data.paymentDeadline
            is timestamp
          && request.resource.data.paymentDeadline
            > request.time
          && paymentProfileMatchesBooking(
            resource.data.providerId
          );

        let reject =
          resource.data.status in [
            'pending',
            'pending_provider'
          ]
          && request.resource.data.status
            == 'rejected'
          && schedulesHaveState(false);

        let confirmPayment =
          resource.data.status == 'payment_review'
          && resource.data.paymentStatus == 'submitted'
          && request.resource.data.status
            == 'confirmed'
          && request.resource.data.paymentStatus
            == 'paid'
          && request.resource.data.paymentConfirmedAt
            is timestamp;

        let rejectPayment =
          resource.data.status == 'payment_review'
          && request.resource.data.status
            == 'awaiting_payment'
          && request.resource.data.paymentStatus
            == 'rejected'
          && request.resource.data.paymentDeadline
            is timestamp
          && request.resource.data.paymentDeadline
            > request.time;

        let complete =
          resource.data.status == 'confirmed'
          && request.resource.data.status
            == 'completed'
          && schedulesHaveState(false);

        let cancel =
          resource.data.status in [
            'pending',
            'pending_provider',
            'awaiting_payment',
            'payment_review',
            'confirmed'
          ]
          && request.resource.data.status
            == 'cancelled'
          && schedulesHaveState(false);


        let awardLoyalty =
  resource.data.status == 'completed'
  && resource.data.paymentStatus == 'paid'
  && (
    !('loyaltyPointsAwarded' in resource.data)
    || resource.data.loyaltyPointsAwarded == 0
  )
  && request.resource.data.status == resource.data.status
  && request.resource.data.paymentStatus == resource.data.paymentStatus
  && request.resource.data.loyaltyPointsAwarded is int
  && request.resource.data.loyaltyPointsAwarded >= 0
  && request.resource.data.loyaltyPointsAwardedAt is timestamp;

        return isProvider()
          && resource.data.providerId
            == request.auth.uid
          && request.resource.data.providerId
            == resource.data.providerId
          && request.resource.data.customerId
            == resource.data.customerId
          && request.resource.data.roomId
            == resource.data.roomId
          && request.resource.data.totalAmount
            == resource.data.totalAmount
          && validBookingStatus(
            request.resource.data.status
          )
                    && validPaymentStatus(
            request.resource.data.paymentStatus
          )
          && changed.hasOnly([
            'status',
            'paymentStatus',
            'paymentDeadline',
            'paymentConfirmedAt',
            'receiverBankBin',
            'receiverBankName',
            'receiverAccountNumber',
            'receiverAccountName',
            'loyaltyPointsAwarded',
            'loyaltyPointsAwardedAt',
            'updatedAt'
          ])
          && (
            approve
            || reject
            || confirmPayment
            || rejectPayment
            || complete
            || cancel
            || awardLoyalty
          );
      }

      allow read: if activeUser()
        && (
          resource.data.customerId
            == request.auth.uid
          || resource.data.providerId
            == request.auth.uid
          || isAdmin()
        );

      allow create: if activeUser()
        && request.resource.data.customerId
          == request.auth.uid
        && request.resource.data.providerId
          is string
        && request.resource.data.providerId.size() > 0
        && request.resource.data.guests is int
        && request.resource.data.guests > 0
        && request.resource.data.status in [
          'pending',
          'pending_provider'
        ]
        && request.resource.data.paymentStatus
          == 'unpaid'
        && request.resource.data.paymentMethod
          == 'vietqr'
        && request.resource.data.receiverBankBin
          == ''
        && request.resource.data.receiverAccountNumber
          == ''
        && request.resource.data.receiverAccountName
          == ''
        && validBookingRoom()
        && validBookingTime()
        && validPricingSnapshot()
        && validSchedules();

      allow update: if isAdmin()
        || customerBookingUpdate()
        || providerBookingUpdate();

      allow delete: if isAdmin();
    }

    /*
     * ROOM SCHEDULES
     */
    match /roomSchedules/{scheduleId} {
      function validReservationWrite() {
        let bookingId =
          request.resource.data.lastBookingId;

        let bookingPath = /databases/$(database)
          /documents/bookings/$(bookingId);

        let booking = getAfter(bookingPath).data;

        let reservation = request.resource.data
          .reservations[bookingId];

        let activeStatus = !(booking.status in [
          'completed',
          'cancelled',
          'rejected',
          'expired'
        ]);

        return bookingId is string
          && existsAfter(bookingPath)
          && reservation.bookingId == bookingId
          && reservation.roomId == booking.roomId
          && reservation.providerId
            == booking.providerId
          && reservation.checkIn == booking.checkIn
          && reservation.checkOut == booking.checkOut
          && reservation.active == activeStatus
          && request.resource.data.roomId
            == booking.roomId
          && (
            booking.customerId
              == request.auth.uid
            || booking.providerId
              == request.auth.uid
            || isAdmin()
          );
      }

      allow read: if activeUser();

      allow create: if activeUser()
        && request.resource.data.roomId is string
        && request.resource.data.yearMonth is string
        && request.resource.data.reservations is map
        && request.resource.data.reservations
          .keys()
          .hasOnly([
            request.resource.data.lastBookingId
          ])
        && validReservationWrite();

      allow update: if isAdmin()
        || (
          activeUser()
          && request.resource.data.roomId
            == resource.data.roomId
          && request.resource.data.yearMonth
            == resource.data.yearMonth
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              'reservations',
              'lastBookingId',
              'updatedAt'
            ])
          && request.resource.data.reservations
            .diff(resource.data.reservations)
            .affectedKeys()
            .hasOnly([
              request.resource.data.lastBookingId
            ])
          && validReservationWrite()
        );

      allow delete: if isAdmin();
    }

    /*
     * PROVIDER PAYMENT PROFILES
     */
    match /providerPaymentProfiles/{providerId} {
      function validProviderSubmission() {
        let changed = request.resource.data
          .diff(resource.data)
          .affectedKeys();

        return isProvider()
          && request.auth.uid == providerId
          && request.resource.data.providerId
            == request.auth.uid
          && request.resource.data.bankBin is string
          && request.resource.data.bankBin.size() >= 3
          && request.resource.data.bankCode is string
          && request.resource.data.bankName is string
          && request.resource.data.accountNumber
            is string
          && request.resource.data.accountNumber.size()
            >= 6
          && request.resource.data.accountNumber.size()
            <= 19
          && request.resource.data.accountName is string
          && request.resource.data.accountName.size() >= 2
          && request.resource.data.isVerified == false
          && request.resource.data.verificationStatus
            == 'pending'
          && request.resource.data.rejectionReason == ''
          && request.resource.data.verifiedBy == ''
          && request.resource.data.verifiedAt == null
          && changed.hasOnly([
            'providerId',
            'businessName',
            'bankBin',
            'bankCode',
            'bankName',
            'accountNumber',
            'accountName',
            'isVerified',
            'verificationStatus',
            'rejectionReason',
            'verifiedBy',
            'verifiedAt',
            'createdAt',
            'updatedAt'
          ]);
      }

      allow read: if activeUser()
        && (
          request.auth.uid == providerId
          || isAdmin()
        );

      allow create: if isAdmin()
        || (
          isProvider()
          && request.auth.uid == providerId
          && request.resource.data.providerId
            == request.auth.uid
          && request.resource.data.isVerified == false
          && request.resource.data.verificationStatus
            == 'pending'
        );

      allow update: if isAdmin()
        || validProviderSubmission();

      allow delete: if isAdmin();
    }

    /*
     * COMMISSION INVOICES
     */
    match /commissionInvoices/{invoiceId} {
      function providerSubmitsCommission() {
        let changed = request.resource.data
          .diff(resource.data)
          .affectedKeys();

        return isProvider()
          && resource.data.providerId
            == request.auth.uid
          && request.resource.data.providerId
            == resource.data.providerId
          && request.resource.data.providerName
            == resource.data.providerName
          && request.resource.data.month
            == resource.data.month
          && request.resource.data.year
            == resource.data.year
          && request.resource.data.grossRevenue
            == resource.data.grossRevenue
          && request.resource.data.commissionRate
            == resource.data.commissionRate
          && request.resource.data.commissionAmount
            == resource.data.commissionAmount
          && request.resource.data.bookingIds
            == resource.data.bookingIds
          && request.resource.data.paymentReference
            == resource.data.paymentReference
          && request.resource.data.dueDate
            == resource.data.dueDate
          && resource.data.status in [
            'unpaid',
            'overdue',
            'rejected'
          ]
          && request.resource.data.status
            == 'payment_review'
          && request.resource.data.rejectionReason
            == ''
          && request.resource.data.paymentSubmittedAt
            is timestamp
          && validCommissionStatus(
            request.resource.data.status
          )
          && changed.hasOnly([
            'status',
            'paymentSubmittedAt',
            'rejectionReason',
            'updatedAt'
          ]);
      }

      allow read: if activeUser()
        && (
          resource.data.providerId
            == request.auth.uid
          || isAdmin()
        );

      allow create: if isAdmin();

      allow update: if isAdmin()
        || providerSubmitsCommission();

      allow delete: if isAdmin();
    }
/*
 * ROOM REVIEWS
 *
 * Review đánh giá phòng, không đánh giá trực tiếp khách sạn.
 * Document ID bằng bookingId để mỗi đơn chỉ có một review.
 */
match /reviews/{reviewId} {
  function reviewBookingPath() {
    return /databases/$(database)
      /documents/bookings/$(reviewId);
  }

  function reviewBookingExists() {
    return exists(reviewBookingPath());
  }

  function reviewBooking() {
    return get(reviewBookingPath()).data;
  }

  function validSeverityForRating() {
  let rating = request.resource.data.rating;
  let severity = request.resource.data.severity;

  return rating == 1
    ? severity == 'critical'
    : rating == 2
      ? severity in ['high', 'critical']
      : rating == 3
        ? severity == 'warning'
        : severity == 'normal';
}

function expectedModerationStatus(severity) {
  return severity == 'normal'
    ? 'not_required'
    : 'pending_review';
}

function expectedProviderActionRequired(severity) {
  return severity in ['high', 'critical'];
}

  function validReviewRating() {
    return request.resource.data.rating is int
      && request.resource.data.rating >= 1
      && request.resource.data.rating <= 5;
  }

  function validReviewComment() {
    return request.resource.data.comment is string
      && request.resource.data.comment.size() >= 5
      && request.resource.data.comment.size() <= 1500;
  }

  function validSeverity() {
    return request.resource.data.severity in [
      'normal',
      'warning',
      'high',
      'critical'
    ];
  }

  function validModerationStatus() {
    return request.resource.data.moderationStatus in [
      'not_required',
      'pending_review',
      'investigating',
      'provider_contacted',
      'resolved',
      'dismissed'
    ];
  }

  function validReviewCreateData() {
    return request.resource.data.keys().hasOnly([
        'targetType',
        'bookingId',
        'customerId',
        'customerName',
        'providerId',
        'hotelId',
        'hotelName',
        'roomId',
        'roomNumber',
        'roomType',
        'rating',
        'comment',
        'providerReply',
        'status',
        'severity',
        'moderationStatus',
        'adminNote',
        'assignedAdminId',
        'providerActionRequired',
        'violationRecordId',
        'createdAt',
        'updatedAt',
        'repliedAt',
        'reviewedAt',
        'resolvedAt'
      ])
      && request.resource.data.targetType == 'room'
      && request.resource.data.bookingId == reviewId

      && request.resource.data.customerId
        == request.auth.uid
      && request.resource.data.customerName is string
      && request.resource.data.customerName.size() >= 1
      && request.resource.data.customerName.size() <= 150

      && request.resource.data.providerId
        == reviewBooking().providerId
      && request.resource.data.hotelId
        == reviewBooking().hotelId
      && request.resource.data.hotelName
        == reviewBooking().hotelName
      && request.resource.data.roomId
        == reviewBooking().roomId
      && request.resource.data.roomNumber
        == reviewBooking().roomNumber
      && request.resource.data.roomType
        == reviewBooking().roomType

      && validReviewRating()
      && validReviewComment()

      && request.resource.data.providerReply == ''
      && request.resource.data.status == 'published'

      && validSeverity()
&& validSeverityForRating()

&& validModerationStatus()
&& request.resource.data.moderationStatus
  == expectedModerationStatus(
    request.resource.data.severity
  )

&& request.resource.data.adminNote == ''
&& request.resource.data.assignedAdminId == ''
&& request.resource.data.providerActionRequired
  == expectedProviderActionRequired(
    request.resource.data.severity
  )
&& request.resource.data.violationRecordId == ''
      && request.resource.data.createdAt is timestamp
      && request.resource.data.updatedAt is timestamp
      && request.resource.data.repliedAt == null
      && request.resource.data.reviewedAt == null
      && request.resource.data.resolvedAt == null;
  }

  function customerCreatesReview() {
    return activeUser()
      && reviewBookingExists()
      && reviewBooking().customerId
        == request.auth.uid
      && reviewBooking().status == 'completed'
      && validReviewCreateData();
  }

  function customerUpdatesReview() {
    let changed = request.resource.data
      .diff(resource.data)
      .affectedKeys();

    return activeUser()
      && resource.data.customerId
        == request.auth.uid

      && request.resource.data.targetType
        == resource.data.targetType
      && request.resource.data.bookingId
        == resource.data.bookingId
      && request.resource.data.customerId
        == resource.data.customerId
      && request.resource.data.customerName
        == resource.data.customerName
      && request.resource.data.providerId
        == resource.data.providerId
      && request.resource.data.hotelId
        == resource.data.hotelId
      && request.resource.data.hotelName
        == resource.data.hotelName
      && request.resource.data.roomId
        == resource.data.roomId
      && request.resource.data.roomNumber
        == resource.data.roomNumber
      && request.resource.data.roomType
        == resource.data.roomType
      && request.resource.data.providerReply
        == resource.data.providerReply
      && request.resource.data.status
        == resource.data.status
      && request.resource.data.createdAt
        == resource.data.createdAt
      && request.resource.data.repliedAt
        == resource.data.repliedAt
      && resource.data.get(
    'violationRecordId',
    ''
  ) == ''
&& request.resource.data.get(
    'violationRecordId',
    ''
  ) == resource.data.get(
    'violationRecordId',
    ''
  )

      && validReviewRating()
      && validReviewComment()

      && validSeverity()
&& validSeverityForRating()
&& validModerationStatus()

&& request.resource.data.moderationStatus
  == expectedModerationStatus(
    request.resource.data.severity
  )

&& request.resource.data.providerActionRequired
  == expectedProviderActionRequired(
    request.resource.data.severity
  )

      && request.resource.data.adminNote == ''
      && request.resource.data.assignedAdminId == ''
      && request.resource.data.reviewedAt == null
      && request.resource.data.resolvedAt == null
      && request.resource.data.updatedAt is timestamp

      && changed.hasOnly([
        'rating',
        'comment',
        'severity',
        'moderationStatus',
        'adminNote',
        'assignedAdminId',
        'providerActionRequired',
        'reviewedAt',
        'resolvedAt',
        'updatedAt'
      ]);
  }

  function providerRepliesToReview() {
    let changed = request.resource.data
      .diff(resource.data)
      .affectedKeys();

    let validReply =
      (
        request.resource.data.providerReply is string
        && request.resource.data.providerReply.size() >= 2
        && request.resource.data.providerReply.size() <= 1000
        && request.resource.data.repliedAt is timestamp
      )
      || (
        request.resource.data.providerReply == ''
        && request.resource.data.repliedAt == null
      );

    return isProvider()
      && resource.data.providerId
        == request.auth.uid
      && request.resource.data.providerId
        == resource.data.providerId
      && request.resource.data.customerId
        == resource.data.customerId
      && request.resource.data.bookingId
        == resource.data.bookingId
      && request.resource.data.hotelId
        == resource.data.hotelId
      && request.resource.data.roomId
        == resource.data.roomId
      && request.resource.data.rating
        == resource.data.rating
      && request.resource.data.comment
        == resource.data.comment
      && request.resource.data.status
        == resource.data.status
      && request.resource.data.severity
        == resource.data.severity
      && request.resource.data.moderationStatus
        == resource.data.moderationStatus
      && request.resource.data.adminNote
        == resource.data.adminNote
      && request.resource.data.assignedAdminId
        == resource.data.assignedAdminId
      && request.resource.data.providerActionRequired
        == resource.data.providerActionRequired
        && request.resource.data.get(
    'violationRecordId',
    ''
  ) == resource.data.get(
    'violationRecordId',
    ''
  )
      && request.resource.data.reviewedAt
        == resource.data.reviewedAt
      && request.resource.data.resolvedAt
        == resource.data.resolvedAt
      && request.resource.data.updatedAt is timestamp
      && validReply
      && changed.hasOnly([
        'providerReply',
        'repliedAt',
        'updatedAt'
      ]);
  }

  allow get: if activeUser()
    && (
      (
        reviewBookingExists()
        && reviewBooking().customerId
          == request.auth.uid
      )
      || isAdmin()
      || resource.data.status == 'published'
      || resource.data.customerId
        == request.auth.uid
      || resource.data.providerId
        == request.auth.uid
    );

  allow list: if activeUser()
    && (
      resource.data.status == 'published'
      || resource.data.customerId
        == request.auth.uid
      || resource.data.providerId
        == request.auth.uid
      || isAdmin()
    );

  allow create: if customerCreatesReview();

  /*
   * Admin được cập nhật moderation, ghi chú, trạng thái
   * hiển thị và phân công xử lý.
   */
  allow update: if isAdmin()
    || customerUpdatesReview()
    || providerRepliesToReview();

  allow delete: if isAdmin();
}

     /*
 * VIOLATION RECORDS
 */
match /violationRecords/{violationId} {
  function validViolationCreateData() {
    return request.resource.data.keys().hasOnly([
        'reviewId',
        'bookingId',
        'hotelId',
        'roomId',
        'providerId',
        'customerId',
        'hotelName',
        'roomNumber',
        'customerName',
        'severity',
        'violationType',
        'title',
        'description',
        'evidenceUrls',
        'bookingAmount',
        'baseCommissionRate',
        'penaltyRate',
        'penaltyAmount',
        'status',
        'providerExplanation',
        'appealNote',
        'adminNote',
        'createdBy',
        'commissionApplied',
        'commissionInvoiceId',
        'createdAt',
        'updatedAt',
        'issuedAt',
        'confirmedAt',
        'resolvedAt'
      ])
      && request.resource.data.reviewId is string
      && request.resource.data.reviewId.size() > 0
      && request.resource.data.bookingId is string
      && request.resource.data.bookingId.size() > 0
      && request.resource.data.providerId is string
      && request.resource.data.providerId.size() > 0
      && request.resource.data.customerId is string
      && request.resource.data.violationType is string
      && validViolationType(request.resource.data.violationType)
      && request.resource.data.title is string
      && request.resource.data.title.size() >= 5
      && request.resource.data.title.size() <= 150
      && request.resource.data.description is string
      && request.resource.data.description.size() >= 20
      && request.resource.data.description.size() <= 2000
      && request.resource.data.evidenceUrls is list
      && request.resource.data.bookingAmount is number
      && request.resource.data.bookingAmount > 0
      && request.resource.data.baseCommissionRate is number
      && request.resource.data.baseCommissionRate >= 0
      && request.resource.data.baseCommissionRate <= 1
      && request.resource.data.penaltyRate == 0.05
      && request.resource.data.penaltyAmount == request.resource.data.bookingAmount * 0.05
      && request.resource.data.status in [
        'draft',
        'waitingProvider'
      ]
      && (
        (
          request.resource.data.status == 'draft'
          && request.resource.data.issuedAt == null
        )
        || (
          request.resource.data.status == 'waitingProvider'
          && request.resource.data.issuedAt is timestamp
        )
      )
      && request.resource.data.providerExplanation == ''
      && request.resource.data.appealNote == ''
      && request.resource.data.adminNote == ''
      && request.resource.data.createdBy == request.auth.uid
      && request.resource.data.commissionApplied == false
      && request.resource.data.commissionInvoiceId == null
      && request.resource.data.createdAt is timestamp
      && request.resource.data.updatedAt is timestamp
      && request.resource.data.confirmedAt == null
      && request.resource.data.resolvedAt == null;
  }

  function providerSubmitsExplanation() {
    let changed = request.resource.data.diff(resource.data).affectedKeys();

    return isProvider()
      && resource.data.providerId == request.auth.uid
      && resource.data.status in [
        'waitingProvider',
        'investigating'
      ]
      && request.resource.data.status == 'investigating'
      && request.resource.data.providerExplanation is string
      && request.resource.data.providerExplanation.size() >= 10
      && request.resource.data.providerExplanation.size() <= 2000
      && request.resource.data.updatedAt is timestamp
      && changed.hasOnly([
        'providerExplanation',
        'status',
        'updatedAt'
      ]);
  }

  function providerSubmitsAppeal() {
    let changed = request.resource.data.diff(resource.data).affectedKeys();

    return isProvider()
      && resource.data.providerId == request.auth.uid
      && resource.data.status == 'confirmed'
      && resource.data.commissionApplied == false
      && request.resource.data.status == 'appealed'
      && request.resource.data.appealNote is string
      && request.resource.data.appealNote.size() >= 10
      && request.resource.data.appealNote.size() <= 2000
      && request.resource.data.updatedAt is timestamp
      && changed.hasOnly([
        'appealNote',
        'status',
        'updatedAt'
      ]);
  }

  function validAdminViolationTransition() {
    let oldStatus = resource.data.status;
    let newStatus = request.resource.data.status;

    return oldStatus == newStatus
      || (
        oldStatus == 'draft'
        && newStatus in [
          'waitingProvider',
          'cancelled'
        ]
      )
      || (
        oldStatus == 'investigating'
        && newStatus in [
          'confirmed',
          'noPenalty'
        ]
      )
      || (
        oldStatus == 'appealed'
        && newStatus in [
          'confirmed',
          'noPenalty'
        ]
      )
      || (
        oldStatus == 'confirmed'
        && newStatus == 'paid'
      );
  }

  function unchangedViolationBaseFields() {
    return request.resource.data.reviewId == resource.data.reviewId
      && request.resource.data.bookingId == resource.data.bookingId
      && request.resource.data.hotelId == resource.data.hotelId
      && request.resource.data.roomId == resource.data.roomId
      && request.resource.data.providerId == resource.data.providerId
      && request.resource.data.customerId == resource.data.customerId
      && request.resource.data.hotelName == resource.data.hotelName
      && request.resource.data.roomNumber == resource.data.roomNumber
      && request.resource.data.customerName == resource.data.customerName
      && request.resource.data.severity == resource.data.severity
      && request.resource.data.violationType == resource.data.violationType
      && request.resource.data.title == resource.data.title
      && request.resource.data.description == resource.data.description
      && request.resource.data.evidenceUrls == resource.data.evidenceUrls
      && request.resource.data.createdBy == resource.data.createdBy
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.bookingAmount == resource.data.bookingAmount
      && request.resource.data.baseCommissionRate == resource.data.baseCommissionRate
      && request.resource.data.penaltyRate == resource.data.penaltyRate
      && request.resource.data.penaltyAmount == resource.data.penaltyAmount;
  }

  function adminUpdatesViolation() {
    let changed = request.resource.data.diff(resource.data).affectedKeys();
    let oldStatus = resource.data.status;
    let newStatus = request.resource.data.status;

    return isAdmin()
      && request.resource.data.keys().hasOnly(resource.data.keys())
      && validViolationStatus(newStatus)
      && validAdminViolationTransition()
      && unchangedViolationBaseFields()
      && request.resource.data.providerExplanation == resource.data.providerExplanation
      && request.resource.data.appealNote == resource.data.appealNote
      && request.resource.data.updatedAt is timestamp
      && (
        (
          oldStatus == 'draft'
          && newStatus == 'waitingProvider'
          && request.resource.data.issuedAt is timestamp
          && request.resource.data.adminNote == resource.data.adminNote
          && request.resource.data.confirmedAt == null
          && request.resource.data.resolvedAt == null
          && request.resource.data.commissionApplied == false
          && request.resource.data.commissionInvoiceId == null
          && changed.hasOnly([
            'status',
            'issuedAt',
            'updatedAt'
          ])
        )
        || (
          oldStatus == 'draft'
          && newStatus == 'cancelled'
          && request.resource.data.adminNote is string
          && request.resource.data.adminNote.size() >= 5
          && request.resource.data.confirmedAt == null
          && request.resource.data.resolvedAt is timestamp
          && request.resource.data.commissionApplied == false
          && request.resource.data.commissionInvoiceId == null
          && changed.hasOnly([
            'status',
            'adminNote',
            'resolvedAt',
            'updatedAt'
          ])
        )
        || (
          oldStatus in [
            'investigating',
            'appealed'
          ]
          && newStatus == 'confirmed'
          && request.resource.data.adminNote is string
          && request.resource.data.adminNote.size() >= 5
          && request.resource.data.confirmedAt is timestamp
          && request.resource.data.resolvedAt == null
          && request.resource.data.commissionApplied == false
          && request.resource.data.commissionInvoiceId == null
          && changed.hasOnly([
            'status',
            'adminNote',
            'confirmedAt',
            'resolvedAt',
            'updatedAt'
          ])
        )
        || (
          oldStatus in [
            'investigating',
            'appealed'
          ]
          && newStatus == 'noPenalty'
          && request.resource.data.adminNote is string
          && request.resource.data.adminNote.size() >= 5
          && request.resource.data.confirmedAt == null
          && request.resource.data.resolvedAt is timestamp
          && request.resource.data.commissionApplied == false
          && request.resource.data.commissionInvoiceId == null
          && changed.hasOnly([
            'status',
            'adminNote',
            'confirmedAt',
            'resolvedAt',
            'commissionApplied',
            'commissionInvoiceId',
            'updatedAt'
          ])
        )
        || (
          oldStatus == 'confirmed'
          && newStatus == 'paid'
          && request.resource.data.commissionApplied == resource.data.commissionApplied
          && request.resource.data.commissionInvoiceId == resource.data.commissionInvoiceId
          && request.resource.data.resolvedAt is timestamp
          && changed.hasOnly([
            'status',
            'resolvedAt',
            'updatedAt'
          ])
        )
      );
  }

  allow read: if activeUser()
    && (
      isAdmin()
      || resource.data.providerId == request.auth.uid
    );

  allow create: if isAdmin()
    && validViolationCreateData();

  allow update: if adminUpdatesViolation()
    || providerSubmitsExplanation()
    || providerSubmitsAppeal();

  allow delete: if isAdmin()
    && (
      resource.data.status == 'draft'
      || resource.data.status == 'cancelled'
    );
}

/*
 * TRAVEL PLACES
 */
match /travelPlaces/{placeId} {
  allow read: if activeUser();
  allow create, update, delete: if isAdmin();
}

/*
 * SAVED PLACES
 */
match /savedPlaces/{savedPlaceId} {
  function savedPlacePath() {
    return /databases/$(database)
      /documents/savedPlaces/$(savedPlaceId);
  }

  function savedPlaceOwnerCreate() {
    return activeUser()
      && request.resource.data.userId == request.auth.uid;
  }

  function savedPlaceOwnerRead() {
    return activeUser()
      && resource.data.userId == request.auth.uid;
  }

  function validSavedPlaceType(type) {
    return type in [
      'hotel',
      'travelPlace'
    ];
  }

  function validSavedPlaceData() {
    return request.resource.data.keys().hasOnly([
      'userId',
      'placeId',
      'name',
      'type',
      'imageUrl',
      'address',
      'province',
      'district',
      'rating',
      'note',
      'createdAt'
    ])
    && request.resource.data.userId == request.auth.uid
    && request.resource.data.placeId is string
    && request.resource.data.placeId.size() > 0
    && request.resource.data.name is string
    && request.resource.data.name.size() > 0
    && request.resource.data.name.size() <= 200
    && validSavedPlaceType(request.resource.data.type)
    && request.resource.data.imageUrl is string
    && request.resource.data.imageUrl.size() <= 1000
    && request.resource.data.address is string
    && request.resource.data.address.size() <= 500
    && request.resource.data.province is string
    && request.resource.data.province.size() <= 100
    && request.resource.data.district is string
    && request.resource.data.district.size() <= 100
    && request.resource.data.rating is number
    && request.resource.data.rating >= 0
    && request.resource.data.rating <= 5
    && request.resource.data.note is string
    && request.resource.data.note.size() <= 500;
  }

  allow get: if activeUser()
    && (
      isAdmin()
      || !exists(savedPlacePath())
      || resource.data.userId == request.auth.uid
    );

  allow list: if activeUser()
    && (
      isAdmin()
      || resource.data.userId == request.auth.uid
    );

  allow create: if savedPlaceOwnerCreate()
    && validSavedPlaceData();

  allow update: if savedPlaceOwnerRead()
    && request.resource.data.userId == resource.data.userId
    && request.resource.data.placeId == resource.data.placeId
    && request.resource.data.type == resource.data.type
    && validSavedPlaceData();

  allow delete: if savedPlaceOwnerRead() || isAdmin();
}
/*
 * VOUCHERS
 * Admin tạo/sửa/xóa voucher. Khách đăng nhập được đọc voucher đang bật.
 */
match /vouchers/{voucherId} {
  function validVoucherTarget(target) {
    return target in [
      'all',
      'booking',
      'travelActivity'
    ];
  }

  function validDiscountType(type) {
    return type in [
      'percent',
      'fixedAmount'
    ];
  }

  function customerCanReadVoucher() {
    return activeUser()
      && resource.data.isActive == true;
  }

  function validAdminVoucherData() {
    return request.resource.data.code is string
      && request.resource.data.code.size() >= 2
      && request.resource.data.code.size() <= 40
      && request.resource.data.title is string
      && request.resource.data.title.size() >= 2
      && request.resource.data.title.size() <= 160
      && request.resource.data.description is string
      && request.resource.data.description.size() <= 2000
      && validDiscountType(request.resource.data.discountType)
      && request.resource.data.discountValue is number
      && request.resource.data.discountValue > 0
      && request.resource.data.maxDiscountAmount is number
      && request.resource.data.maxDiscountAmount >= 0
      && request.resource.data.minOrderAmount is number
      && request.resource.data.minOrderAmount >= 0
      && request.resource.data.pointsRequired is int
      && request.resource.data.pointsRequired >= 0
      && request.resource.data.quantity is int
      && request.resource.data.quantity >= 0
      && request.resource.data.usedCount is int
      && request.resource.data.usedCount >= 0
      && validVoucherTarget(request.resource.data.target)
      && request.resource.data.terms is string
      && request.resource.data.terms.size() <= 3000
      && request.resource.data.isActive is bool
      && request.resource.data.startAt is timestamp
      && request.resource.data.endAt is timestamp
      && request.resource.data.endAt >= request.resource.data.startAt;
  }

  function userIncrementsUsedCountOnly() {
    let changed = request.resource.data
      .diff(resource.data)
      .affectedKeys();

    return activeUser()
      && resource.data.isActive == true
      && changed.hasOnly([
        'usedCount',
        'updatedAt'
      ])
      && request.resource.data.usedCount is int
      && request.resource.data.usedCount >= 1
      && (
        !('usedCount' in resource.data)
        || request.resource.data.usedCount == resource.data.usedCount + 1
      )
      && (
        !('quantity' in resource.data)
        || resource.data.quantity <= 0
        || request.resource.data.usedCount <= resource.data.quantity
      );
  }

  allow read: if isAdmin() || customerCanReadVoucher();

  allow create: if isAdmin()
    && request.resource.data.keys().hasOnly([
      'code',
      'title',
      'description',
      'discountType',
      'discountValue',
      'maxDiscountAmount',
      'minOrderAmount',
      'pointsRequired',
      'quantity',
      'usedCount',
      'target',
      'terms',
      'isActive',
      'startAt',
      'endAt',
      'createdBy',
      'createdAt',
      'updatedAt'
    ])
    && request.resource.data.createdBy == request.auth.uid
    && validAdminVoucherData();

  allow update: if (
      isAdmin()
      && request.resource.data.keys().hasOnly(resource.data.keys())
      && validAdminVoucherData()
    )
    || userIncrementsUsedCountOnly();

  allow delete: if isAdmin();
}
/*
 * USER VOUCHERS
 */
match /userVouchers/{userVoucherId} {
  function userVoucherDocPath() {
    return /databases/$(database)
      /documents/userVouchers/$(userVoucherId);
  }

  function userVoucherOwnerCreate() {
    return activeUser()
      && request.resource.data.userId == request.auth.uid;
  }

  function userVoucherOwnerRead() {
    return activeUser()
      && resource.data.userId == request.auth.uid;
  }

  function validUserVoucherStatus(status) {
    return status in [
      'available',
      'reserved',
      'used',
      'expired'
    ];
  }

  function validUserVoucherCreateData() {
    return request.resource.data.userId is string
      && request.resource.data.userId == request.auth.uid
      && request.resource.data.voucherId is string
      && request.resource.data.voucherId.size() > 0
      && request.resource.data.code is string
      && request.resource.data.code.size() > 0
      && request.resource.data.title is string
      && request.resource.data.title.size() > 0
      && request.resource.data.status == 'available'
      && request.resource.data.redeemedByPoints is bool
      && request.resource.data.pointsSpent is int
      && request.resource.data.pointsSpent >= 0
      && request.resource.data.bookingId is string;
  }

  function validUserVoucherOwnerUpdate() {
    return request.resource.data.userId == resource.data.userId
      && request.resource.data.voucherId == resource.data.voucherId
      && request.resource.data.code == resource.data.code
      && request.resource.data.title == resource.data.title
      && request.resource.data.redeemedByPoints == resource.data.redeemedByPoints
      && request.resource.data.pointsSpent == resource.data.pointsSpent
      && validUserVoucherStatus(request.resource.data.status);
  }

  allow get: if activeUser()
    && (
      isAdmin()
      || !exists(userVoucherDocPath())
      || resource.data.userId == request.auth.uid
    );

  allow list: if activeUser()
    && (
      isAdmin()
      || resource.data.userId == request.auth.uid
    );

  allow create: if userVoucherOwnerCreate()
    && request.resource.data.keys().hasOnly([
      'userId',
      'voucherId',
      'code',
      'title',
      'status',
      'redeemedByPoints',
      'pointsSpent',
      'bookingId',
      'usedAt',
      'expiredAt',
      'createdAt',
      'updatedAt'
    ])
    && validUserVoucherCreateData();

  allow update: if (
      userVoucherOwnerRead()
      && request.resource.data.userId == resource.data.userId
      && request.resource.data.keys().hasOnly([
        'userId',
        'voucherId',
        'code',
        'title',
        'status',
        'redeemedByPoints',
        'pointsSpent',
        'bookingId',
        'usedAt',
        'expiredAt',
        'createdAt',
        'updatedAt'
      ])
      && validUserVoucherOwnerUpdate()
    )
    || isAdmin();

  allow delete: if isAdmin();
}

/*
 * LOYALTY POINTS
 */
match /loyaltyPoints/{userId} {
  function providerCanAwardPoints() {
    return isProvider()
      && request.resource.data.userId == userId;
  }

  allow read: if activeUser()
    && (
      request.auth.uid == userId
      || isProvider()
      || isAdmin()
    );

  allow create: if (
      activeUser()
      && request.auth.uid == userId
      && request.resource.data.userId == request.auth.uid
    )
    || providerCanAwardPoints()
    || isAdmin();

  allow update: if (
      activeUser()
      && request.auth.uid == userId
      && request.resource.data.userId == userId
    )
    || providerCanAwardPoints()
    || isAdmin();

  allow delete: if isAdmin();
}
/*
 * POINT TRANSACTIONS
 */
match /pointTransactions/{transactionId} {
  function pointTransactionOwnerCreate() {
    return activeUser()
      && request.resource.data.userId == request.auth.uid;
  }

  function pointTransactionOwnerRead() {
    return activeUser()
      && resource.data.userId == request.auth.uid;
  }

  function providerCreatesEarnTransaction() {
    return isProvider()
      && request.resource.data.type == 'earn'
      && request.resource.data.source == 'booking'
      && request.resource.data.points is int
      && request.resource.data.points > 0
      && request.resource.data.referenceId is string;
  }

  function validPointTransactionType(type) {
    return type in [
      'earn',
      'redeem',
      'spend',
      'refund',
      'adjust',
      'adjustment'
    ];
  }

  allow read: if pointTransactionOwnerRead() || isAdmin();

  allow create: if (
      pointTransactionOwnerCreate()
      || providerCreatesEarnTransaction()
      || isAdmin()
    )
    && request.resource.data.userId is string
    && request.resource.data.points is int
    && validPointTransactionType(request.resource.data.type);

  allow update, delete: if isAdmin();
}
/*
 * TRAVEL CHAT SESSIONS
 */
match /travelChatSessions/{sessionId} {
  function chatSessionPath() {
    return /databases/$(database)
      /documents/travelChatSessions/$(sessionId);
  }

  function chatSessionOwnerCreate() {
    return activeUser()
      && request.resource.data.userId == request.auth.uid;
  }

  function chatSessionOwnerRead() {
    return activeUser()
      && resource.data.userId == request.auth.uid;
  }

  // Khi tạo cuộc trò chuyện mới, ứng dụng cần get() ID vừa sinh để
  // kiểm tra document đã tồn tại hay chưa. Document chưa tồn tại không có
  // resource.data, nên phải cho phép riêng trường hợp này.
  allow get: if isAdmin()
    || (
      activeUser()
      && (
        !exists(chatSessionPath())
        || resource.data.userId == request.auth.uid
      )
    );

  // Truy vấn lịch sử vẫn bắt buộc lọc theo userId của người đăng nhập.
  allow list: if chatSessionOwnerRead() || isAdmin();

  allow create: if chatSessionOwnerCreate()
    && request.resource.data.keys().hasOnly([
      'userId',
      'title',
      'lastMessage',
      'messageCount',
      'createdAt',
      'updatedAt'
    ])
    && request.resource.data.title is string
    && request.resource.data.title.size() > 0
    && request.resource.data.title.size() <= 120
    && request.resource.data.lastMessage is string
    && request.resource.data.lastMessage.size() <= 500
    && request.resource.data.messageCount is number
    && request.resource.data.messageCount >= 0;

  allow update: if chatSessionOwnerRead()
    && request.resource.data.userId == resource.data.userId
    && request.resource.data.keys().hasOnly([
      'userId',
      'title',
      'lastMessage',
      'messageCount',
      'createdAt',
      'updatedAt'
    ])
    && request.resource.data.title is string
    && request.resource.data.title.size() > 0
    && request.resource.data.title.size() <= 120
    && request.resource.data.lastMessage is string
    && request.resource.data.lastMessage.size() <= 500
    && request.resource.data.messageCount is number
    && request.resource.data.messageCount >= 0;

  allow delete: if chatSessionOwnerRead() || isAdmin();
}
/*
 * TRAVEL CHAT MESSAGES
 */
match /travelChatMessages/{messageId} {
  function chatOwnerCreate() {
    return activeUser()
      && request.resource.data.userId == request.auth.uid;
  }

  function chatOwnerRead() {
    return activeUser()
      && resource.data.userId == request.auth.uid;
  }

  function validChatSender() {
    return (
      'sender' in request.resource.data
      && request.resource.data.sender in [
        'user',
        'ai',
        'assistant',
        'system'
      ]
    )
    || (
      'role' in request.resource.data
      && request.resource.data.role in [
        'user',
        'assistant',
        'system'
      ]
    );
  }

  allow read: if chatOwnerRead() || isAdmin();

  allow create: if chatOwnerCreate()
    && request.resource.data.keys().hasOnly([
      'sessionId',
      'userId',
      'content',
      'sender',
      'role',
      'type',
      'suggestionIds',
      'createdAt'
    ])
    && request.resource.data.sessionId is string
    && request.resource.data.sessionId.size() > 0
    && request.resource.data.content is string
    && request.resource.data.content.size() > 0
    && request.resource.data.content.size() <= 6000
    && validChatSender()
    && (
      !('type' in request.resource.data)
      || request.resource.data.type in [
        'text',
        'suggestion',
        'error'
      ]
    )
    && (
      !('suggestionIds' in request.resource.data)
      || request.resource.data.suggestionIds is list
    );

  allow update: if false;

  allow delete: if chatOwnerRead() || isAdmin();
}
/*
 * TRAVEL SUGGESTIONS
 */
match /travelSuggestions/{suggestionId} {
  allow read: if activeUser();

  allow create: if activeUser();

  allow update, delete: if isAdmin();
}

    /*
     * APPLICATION SETTINGS
     */
    match /appSettings/{settingId} {
      allow read: if activeUser()
        && (
          isProvider()
          || isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    /*
     * HOLIDAY CALENDARS
     */
    match /holidayCalendars/{year} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }

    /*
     * DENY EVERYTHING ELSE
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
